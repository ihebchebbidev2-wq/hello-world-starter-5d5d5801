APP_NAME="AgriTrack API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Leave blank to use local SQLite (auto-created). Set for Postgres on Render.
DATABASE_URL=

CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync

SANCTUM_TOKEN_EXPIRATION=10080
